# --- Telegram ---
BOT_TOKEN=
CHANNEL_ID=
ADMIN_IDS=

# How to send images to Telegram:
# - document: no recompression (best quality)
# - photo: Telegram recompresses
TG_SEND_AS=photo

# Optional caption (no tags in MVP). Leave empty to post just the image.
CAPTION_TEMPLATE=

# --- Paths (supports external disk) ---
DATA_DIR=./data
OUTPUT_DIR=./data/outputs
DB_PATH=./data/db/app.db
HF_HOME=./data/hf_cache
PROMPTS_PATH=./data/prompts.json
ANIMAGINE_RATING=explicit
# --- Scheduler ---
POST_INTERVAL_MIN=20
PAUSED=false

# --- Prompt selection ---
# A = single content topic
# B = content+modifier topic
# AB_RANDOM = random A/B
PROMPT_MODE=AB_RANDOM
PROMPT_MODE_A_WEIGHT=0.5

# Topics matched by this regex are treated as "modifier" in Mode B.
MODIFIER_TOPIC_REGEX=(?i)^(camera settings|lighting)$

# Avoid repeating prompt IDs from last N posts
NO_REPEAT_LAST_N=20

# --- SD / diffusers ---
MODEL_ID=cagliostrolab/animagine-xl-4.0

DTYPE=float16
SAMPLER=euler_a
STEPS=30
CFG=7.0
RESOLUTION_MODE=random
RESOLUTION_PRESETS=1024x1024,1344x768,768x1344
WIDTH=512
HEIGHT=768
SEED=
NEGATIVE_DEFAULT=lowres, blurry, text, watermark, logo, worst quality, bad anatomy, censorship

# --- Filters ---
# fast: heuristics
# strict: heuristics + OCR (requires pytesseract + tesseract installed)
WATERMARK_MODE=off
REJECT_IF_TEXT_LIKELY=false

# Optional NSFW filter (MVP off)
NSFW_FILTER_ENABLED=false

# --- Subject slot files (optional) ---
SUBJECTS_1_PATH=./data/subjects_1.txt
SUBJECTS_2_PATH=./data/subjects_2.txt
SUBJECTS_3_PATH=./data/subjects_3.txt

# --- Optional LLM adapter ---
LLM_MODE=openai_compatible
LLM_BASE_URL=http://26.241.59.135:1234
LLM_API_KEY=local
LLM_MODEL=dolphin3.0-llama3.1-8b
